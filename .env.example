# VeriVote local/demo environment

# API
PORT=3001
VERIVOTE_PERSISTENCE=memory
VERIVOTE_SQLITE_PATH=./data/verivote.db

# Web
VITE_API_BASE_URL=http://localhost:3001

# Demo tooling
VERIVOTE_API_BASE_URL=http://localhost:3001

# Blockchain audit
# local-mock is sufficient for quick demo. Use hardhat for local chain transactions.
BLOCKCHAIN_AUDIT_MODE=local-mock
HARDHAT_RPC_URL=http://127.0.0.1:8545
HARDHAT_PRIVATE_KEY=
AUDIT_CONTRACT_ADDRESS=
VERIVOTE_AUDIT_CONTRACT_ADDRESS=

# Tally verifier
# Set this if deploy-audit should reuse an existing TallyVerifier address.
VERIVOTE_TALLY_VERIFIER_ADDRESS=

# ZK artifact directories
VERIVOTE_ZK_ARTIFACT_DIR=./zk-artifacts/valid-vote
VERIVOTE_ZK_TALLY_ARTIFACT_DIR=./zk-artifacts/tally-correctness

# Deployment safety notes
# In production, disable /attack/* at the reverse proxy and replace wildcard CORS.
